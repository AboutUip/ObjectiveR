{
  "$schema": "vscode://schemas/icon-theme",
  "iconDefinitions": {
    "_file": {
      "iconPath": "./icons/file.svg"
    },
    "_folder": {
      "iconPath": "./icons/folder.svg"
    },
    "_folder_open": {
      "iconPath": "./icons/folder-open.svg"
    },
    "obr": {
      "iconPath": "./icons/obr.svg"
    },
    "mr": {
      "iconPath": "./icons/mr.svg"
    }
  },
  "file": "_file",
  "folder": "_folder",
  "folderExpanded": "_folder_open",
  "rootFolder": "_folder",
  "rootFolderExpanded": "_folder_open",
  "fileExtensions": {
    "obr": "obr",
    "mr": "mr"
  }
}
