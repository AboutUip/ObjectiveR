{
  "name": "objective-r-file-support",
  "displayName": "ObjectiveR File Support",
  "description": "Obr / ModuleR: syntax highlighting, completion, hover, diagnostics, snippets, icons.",
  "icon": "icons/obr.svg",
  "version": "0.2.0",
  "main": "./extension.js",
  "publisher": "kitepromiss",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "configuration": {
      "title": "ObjectiveR",
      "properties": {
        "objectiveR.completion.enable": {
          "type": "boolean",
          "default": true,
          "description": "启用自动补全（关键字、工作区函数、std::、片段）。"
        },
        "objectiveR.diagnostics.enable": {
          "type": "boolean",
          "default": true,
          "description": "启用全部语法/语义诊断；关闭后不在编辑器中显示波浪线。"
        },
        "objectiveR.diagnostics.structural": {
          "type": "boolean",
          "default": true,
          "description": "括号/引号/块注释匹配（不依赖工作区索引）。"
        },
        "objectiveR.diagnostics.workspace": {
          "type": "boolean",
          "default": true,
          "description": "工作区级检查：import、deRfun 声明形式、重复签名等。"
        },
        "objectiveR.semanticHighlighting.enable": {
          "type": "boolean",
          "default": true,
          "description": "语义高亮（参数、局部变量、函数名、std:: 命名空间段）；依赖主题支持 editor.semanticHighlighting。"
        },
        "objectiveR.project.scanMode": {
          "type": "string",
          "enum": [
            "workspace",
            "mainObrAndLink"
          ],
          "default": "workspace",
          "description": "workspace：索引全部工作区 *.obr/*.mr。mainObrAndLink：解析 main.obr 中 #LINK 路径项，在 projectRoot 下并集扫描（与 Blink 项目根一致）。"
        }
      }
    },
    "configurationDefaults": {
      "[objective-r-obr]": {
        "editor.semanticHighlighting.enabled": true
      },
      "[objective-r-mr]": {
        "editor.semanticHighlighting.enabled": true
      }
    },
    "languages": [
      {
        "id": "objective-r-obr",
        "aliases": [
          "ObjectiveR Obr",
          "Obr"
        ],
        "extensions": [
          ".obr"
        ],
        "icon": {
          "light": "./icons/obr.svg",
          "dark": "./icons/obr.svg"
        },
        "configuration": "./language-configuration-obr.json"
      },
      {
        "id": "objective-r-mr",
        "aliases": [
          "ObjectiveR ModuleR",
          "ModuleR"
        ],
        "extensions": [
          ".mr"
        ],
        "icon": {
          "light": "./icons/mr.svg",
          "dark": "./icons/mr.svg"
        },
        "configuration": "./language-configuration-mr.json"
      }
    ],
    "grammars": [
      {
        "language": "objective-r-obr",
        "scopeName": "source.objective-r",
        "path": "./syntaxes/objective-r.tmLanguage.json"
      },
      {
        "language": "objective-r-mr",
        "scopeName": "source.objective-r",
        "path": "./syntaxes/objective-r.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "objective-r-obr",
        "path": "./snippets/obr.code-snippets"
      },
      {
        "language": "objective-r-mr",
        "path": "./snippets/mr.code-snippets"
      }
    ]
  }
}
